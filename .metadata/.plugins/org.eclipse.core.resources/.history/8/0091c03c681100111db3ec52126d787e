package Trainer3;

public class E3 {

    public static void main(String[] args) {

        String correctUsername = "admin";
        String correctPassword = "12345";


        LoginValidator validate = (username, password) -> username.equals(correctUsername) && password.equals(correctPassword);

        System.out.println(validate.validate("admin", "12345"));  // true
        System.out.println(validate.validate("admin", "11111"));  // false
    }
}
